# NeuroOps — Environment Variables Template
# Copy this to .env and fill in your values
# Never commit .env to git

# ── LLM ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=            # Required. Get at console.anthropic.com
OPENAI_API_KEY=               # Optional. Used as LLM fallback

# ── Kubernetes ───────────────────────────────────────────
KUBECONFIG=~/.kube/config     # Path to your kubeconfig
TARGET_NAMESPACE=neuroops-demo
KUBECONFIG_CONTEXT=           # Optional: named context for multi-cluster support (blank = current)

# ── Observability ────────────────────────────────────────
PROMETHEUS_URL=http://localhost:9090
JAEGER_QUERY_URL=http://localhost:16686
JAEGER_COLLECTOR_URL=http://localhost:14268
OTEL_COLLECTOR_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=neuroops-agent

# ── GitHub ───────────────────────────────────────────────
GITHUB_TOKEN=                 # Required for historian agent + PR creation
GITHUB_REPO=                  # e.g. your-username/neuroops

# ── Inter-service URLs ───────────────────────────────────
DETECTOR_URL=http://localhost:8001
AGENT_URL=http://localhost:8002
REMEDIATOR_URL=http://localhost:8003

# ── Security & Rate Limiting ─────────────────────────────
NEUROOPS_API_KEY=             # Optional: enables X-API-Key header auth on all services
SLACK_APPROVAL_TTL_SECONDS=1800  # Seconds before pending Slack approval expires (default 30 min)

# ── Tuning ───────────────────────────────────────────────
HUMAN_APPROVAL_REQUIRED=true  # Set false to auto-approve all P2 actions in demos
MAX_AGENT_ITERATIONS=10       # Max LangGraph iterations before timeout
ANOMALY_CONTAMINATION=0.05    # Isolation Forest contamination param
CONFIDENCE_THRESHOLD=0.6      # Below this → human escalation
AUTONOMOUS_CONFIDENCE_THRESHOLD=0.65  # Actions above this confidence run autonomously (0.0-1.0)
ALERT_DEDUP_WINDOW_SECONDS=300
NEUROOPS_NON_INTERACTIVE=false  # Set true to skip human approval prompts (CI/testing)

# ── RAG Memory ───────────────────────────────────────────
MEMORY_ENABLED=true
MEMORY_DB_PATH=./checkpoints/memory

# ── Predictive Alerts ────────────────────────────────────
PREDICTIVE_ALERTS_ENABLED=true

# ── Dynamic Model Routing ────────────────────────────────
MODEL_ROUTING_ENABLED=true

# ── Model Checkpoints ────────────────────────────────────
MODEL_PATH=checkpoints/isolation_forest.joblib
SEQ_MODEL_PATH=checkpoints/seq_model.joblib  # Ridge Regression sequence forecaster (joblib)
