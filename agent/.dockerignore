# Python cache and compiled files
__pycache__/
*.pyc
*.pyo
*.pyd

# Test artefacts — tests are not needed inside the container image
tests/
.pytest_cache/
.mypy_cache/

# Coverage reports
.coverage
htmlcov/

# Documentation — not needed in the image
*.md

# Secrets and local env — must never be baked into an image
.env
.env.*

# Git history — not needed in image
.git/
.gitignore

# Virtual environments — container uses its own pip-installed deps
.venv/

# Persisted checkpoints — mounted as a named Docker volume at runtime
checkpoints/
