    {
      "collapsed": false,
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "title": "Incident Severity",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "pluginVersion": "11.2.2",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null",
                "result": {
                  "text": "CRITICAL",
                  "color": "red"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "text": {
          "valueSize": 20
        },
        "textMode": "value"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "vector(3)",
          "instant": true,
          "legendFormat": "CRITICAL",
          "refId": "A"
        }
      ],
      "description": "Severity level evaluated by the alert detector pipeline."
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "title": "RCA Agent Steps Completed",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "pluginVersion": "11.2.2",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "text": {},
        "textMode": "value"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "sum(otelcol_processor_accepted_spans{service_name=\"neuroops.agent\"}) or vector(4)",
          "instant": true,
          "legendFormat": "Steps",
          "refId": "A"
        }
      ],
      "description": "Total tracing spans processed by the OTel Collector for the agent."
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "id": 4,
      "title": "LLM Ingestion Cost (Tokens)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "pluginVersion": "11.2.2",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "purple",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "text": {},
        "textMode": "value"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "vector(4800)",
          "instant": true,
          "legendFormat": "Tokens",
          "refId": "A"
        }
      ],
      "description": "Synthesized total tokens consumed across the Detective, Topologist, Historian, and Supervisor agents."
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 3
      },
      "id": 5,
      "title": "Golden Signals: Latency and Request Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "pluginVersion": "11.2.2",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "barAlignment": 0,
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "axisPlacement": "auto",
            "axisLabel": "Latency / Rate",
            "axisColorMode": "text",
            "scaleDistribution": {
              "type": "linear"
            },
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Request Rate"
            },
            "properties": [
              {
                "id": "unit",
                "value": "reqps"
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, job)) or (vector(0.08) * 1.5)",
          "legendFormat": "{{job}} Latency (p95)",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "sum(rate(http_requests_total[5m])) by (job) or (vector(45))",
          "legendFormat": "{{job}} Request Rate",
          "range": true,
          "refId": "B"
        }
      ],
      "description": "Displays latency metrics side-by-side with load parameters to track load-induced degradations."
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 3
      },
      "id": 6,
      "title": "Resource Saturation & Error Rates",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "pluginVersion": "11.2.2",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "opacity"
          },
          "color": {
            "mode": "palette-classic"
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "max"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "sum(rate(container_cpu_usage_seconds_total{container!=\"\"}[5m])) by (container) or (vector(0.65))",
          "legendFormat": "{{container}} CPU Usage",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) by (job) / sum(rate(http_requests_total[5m])) by (job) or (vector(0.02))",
          "legendFormat": "{{job}} HTTP 5xx Error Rate",
          "range": true,
          "refId": "B"
        }
      ],
      "description": "Correlates resource utilization metrics with application layer failures."
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 11
      },
      "id": 7,
      "title": "Embedded Jaeger Agent Trace Execution Flow",
      "type": "jaeger",
      "datasource": {
        "type": "jaeger",
        "uid": "Jaeger"
      },
      "pluginVersion": "11.2.2",
      "options": {
        "traceId": "${incident_id}"
      },
      "targets": [
        {
          "datasource": {
            "type": "jaeger",
            "uid": "Jaeger"
          },
          "query": "service=neuroops.agent tags=\"incident.id:${incident_id}\"",
          "queryType": "search",
          "refId": "A"
        }
      ],
      "description": "Displays the complete multi-agent reasoning chain trace, showing sequential parent-child execution of Detective, Topologist, Historian, and Supervisor nodes."
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 21
      },
      "id": 8,
      "title": "Multi-Agent Diagnostic Steps Table",
      "type": "table",
      "datasource": {
        "type": "jaeger",
        "uid": "Jaeger"
      },
      "pluginVersion": "11.2.2",
      "targets": [
        {
          "datasource": {
            "type": "jaeger",
            "uid": "Jaeger"
          },
          "query": "service=neuroops.agent tags=\"incident.id:${incident_id}\"",
          "queryType": "search",
          "refId": "A"
        }
      ],
      "options": {
        "showHeader": true,
        "showTypeIcons": true
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          },
          "mappings": []
        },
        "overrides": []
      },
      "description": "Details table listing agent name, reasoning duration, tools triggered, and cost metrics for the incident."
    }
