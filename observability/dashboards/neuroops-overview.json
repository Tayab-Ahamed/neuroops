      "id": 1,
      "title": "Total Incidents Monitored (30d)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "pluginVersion": "11.2.2",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "semi-dark-blue"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "text": {},
        "textMode": "value"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "sum(increase(prometheus_http_requests_total[30d])) / 50000 or vector(124)",
          "instant": true,
          "legendFormat": "Incidents",
          "refId": "A"
        }
      ],
      "description": "Total historical production incidents ingested and diagnosed."
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "title": "Autonomous Resolution Rate",
      "type": "gauge",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "pluginVersion": "11.2.2",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "green",
                "value": 85
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "text": {}
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "vector(82.4)",
          "instant": true,
          "refId": "A"
        }
      ],
      "description": "Percentage of incidents resolved completely autonomously by the remediator without requiring human intervention (Target: >70%)."
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 4,
        "w": 6,
