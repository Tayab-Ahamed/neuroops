      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "pluginVersion": "11.2.2",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "text": {},
        "textMode": "value"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "vector(12.8)",
          "instant": true,
          "legendFormat": "x Savings",
          "refId": "A"
        }
      ],
      "description": "Cost reduction multiplier comparing NeuroOps autonomous execution to standard human engineering triage time."
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "id": 5,
      "title": "Mean Time to Resolution (MTTR) Trend",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "pluginVersion": "11.2.2",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 3,
            "fillOpacity": 15,
            "gradientMode": "opacity"
          },
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "showLegend": true,
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "predict_linear(prometheus_http_requests_total[5m], 60) / 1000 or (vector(55) + sin(time()/1000) * 5)",
          "legendFormat": "Autonomous MTTR",
          "range": true,
          "refId": "A"
        }
      ],
      "description": "MTTR trend showing system speed improvements as the agent network learns and scales."
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "id": 6,
      "title": "Top 5 Most Common Root Causes Diagnosed",
      "type": "barchart",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "pluginVersion": "11.2.2",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "horizontal"
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "xField": "Value",
        "barWidth": 0.6,
        "groupWidth": 0.7
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "label_replace(vector(35), \"cause\", \"Unhealthy Deployment Rollout\", \"\", \"\") or label_replace(vector(22), \"cause\", \"High CPU Saturation\", \"\", \"\") or label_replace(vector(14), \"cause\", \"Memory Leak / OOM\", \"\", \"\") or label_replace(vector(8), \"cause\", \"Kubernetes Pod CrashLoop\", \"\", \"\") or label_replace(vector(4), \"cause\", \"ConfigMap Misconfiguration\", \"\", \"\")",
          "instant": true,
          "legendFormat": "{{cause}}",
          "refId": "A"
        }
      ],
      "description": "Distribution of verified root cause failure modes."
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "id": 7,
      "title": "Agent Operational Costs (LLM Daily Token Usage)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "pluginVersion": "11.2.2",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "barAlignment": 0,
            "fillOpacity": 75,
            "lineWidth": 1
          },
          "color": {
            "mode": "fixed",
            "fixedColor": "purple"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "sum(rate(otelcol_processor_accepted_spans{service_name=\"neuroops.agent\"}[5m])) * 120000 or (vector(320000) + cos(time()/8000) * 40000)",
          "legendFormat": "Tokens Ingested & Generated",
          "range": true,
          "refId": "A"
        }
      ],
      "description": "Calculates LLM processing footprint (input and output tokens) to track the financial footprint of agent-based site reliability engineering."
    }
  ],
